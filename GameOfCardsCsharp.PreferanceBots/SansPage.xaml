<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="GameOfCardsCsharp.PreferanceBots.SansPage"
             Title="Sans Game - 2 Players"
             BackgroundColor="#2D5016">

    <!-- Main Two-Column Layout: Game Area | Control Panel -->
    <Grid ColumnDefinitions="*,350" Padding="10">

        <!-- LEFT COLUMN: Game Board -->
        <Grid Grid.Column="0" 
              RowDefinitions="Auto,*,Auto" 
              Padding="5"
              RowSpacing="10">

            <!-- TOP: AI Bot's Hand -->
            <Border Grid.Row="0" 
                    BackgroundColor="#1A3010" 
                    Stroke="#4A7029"
                    StrokeThickness="2"
                    Padding="10">
                <VerticalStackLayout Spacing="8">
                    <Label x:Name="BotNameLabel"
                           Text="Sans Bot (AI)" 
                           FontSize="18" 
                           FontAttributes="Bold"
                           TextColor="White"
                           HorizontalOptions="Center"/>

                    <Label x:Name="BotTricksLabel"
                           Text="Tricks: 0"
                           FontSize="14"
                           TextColor="LightGray"
                           HorizontalOptions="Center"/>

                    <!-- Bot's Hand (face down in real mode, face up in test mode) -->
                    <CollectionView x:Name="BotHandCollection" 
                                   HeightRequest="100"
                                   HorizontalOptions="Center"
                                   SelectionMode="None">
                        <CollectionView.ItemsLayout>
                            <LinearItemsLayout Orientation="Horizontal" 
                                             ItemSpacing="5"/>
                        </CollectionView.ItemsLayout>
                        <CollectionView.ItemTemplate>
                            <DataTemplate>
                                <Border BackgroundColor="{Binding BackgroundColor}"
                                        Stroke="{Binding BorderColor}"
                                        StrokeThickness="2"
                                        WidthRequest="65"
                                        HeightRequest="90"
                                        Margin="2">
                                    <Border.StrokeShape>
                                        <RoundRectangle CornerRadius="8"/>
                                    </Border.StrokeShape>
                                    <Label Text="{Binding DisplayText}" 
                                           FontSize="28"
                                           FontAttributes="Bold"
                                           TextColor="{Binding TextColor}"
                                           HorizontalOptions="Center"
                                           VerticalOptions="Center"/>
                                </Border>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </VerticalStackLayout>
            </Border>

            <!-- MIDDLE: Play Area (Trick Display) -->
            <Border Grid.Row="1" 
                    BackgroundColor="#1A3010" 
                    Stroke="#4A7029"
                    StrokeThickness="3"
                    Padding="15"
                    VerticalOptions="Fill">
                <Grid RowDefinitions="Auto,*" RowSpacing="10">
                    <!-- Trick Status -->
                    <VerticalStackLayout Grid.Row="0" Spacing="5">
                        <Label x:Name="TrickStatusLabel"
                               Text="Trick 0 / 10"
                               FontSize="16"
                               FontAttributes="Bold"
                               TextColor="White"
                               HorizontalOptions="Center"/>
                        <Label x:Name="CurrentLeaderLabel"
                               Text="Waiting to start..."
                               FontSize="14"
                               TextColor="LightGray"
                               HorizontalOptions="Center"/>
                    </VerticalStackLayout>

                    <!-- Played Cards Display -->
                    <StackLayout Grid.Row="1"
                                HorizontalOptions="Center"
                                VerticalOptions="Center"
                                Orientation="Horizontal"
                                Spacing="30">
                        
                        <!-- Bot's Played Card -->
                        <VerticalStackLayout Spacing="5">
                            <Label Text="Bot"
                                   FontSize="12"
                                   TextColor="LightGray"
                                   HorizontalOptions="Center"/>
                            <Border x:Name="BotPlayedCardBorder"
                                    BackgroundColor="White"
                                    Stroke="Gray"
                                    StrokeThickness="2"
                                    WidthRequest="90"
                                    HeightRequest="120"
                                    IsVisible="False">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="8"/>
                                </Border.StrokeShape>
                                <Label x:Name="BotPlayedCardLabel"
                                       FontSize="36"
                                       FontAttributes="Bold"
                                       TextColor="Black"
                                       HorizontalOptions="Center"
                                       VerticalOptions="Center"/>
                            </Border>
                        </VerticalStackLayout>

                        <!-- Player's Played Card -->
                        <VerticalStackLayout Spacing="5">
                            <Label Text="You"
                                   FontSize="12"
                                   TextColor="LightGray"
                                   HorizontalOptions="Center"/>
                            <Border x:Name="PlayerPlayedCardBorder"
                                    BackgroundColor="White"
                                    Stroke="Blue"
                                    StrokeThickness="2"
                                    WidthRequest="90"
                                    HeightRequest="120"
                                    IsVisible="False">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="8"/>
                                </Border.StrokeShape>
                                <Label x:Name="PlayerPlayedCardLabel"
                                       FontSize="36"
                                       FontAttributes="Bold"
                                       TextColor="Black"
                                       HorizontalOptions="Center"
                                       VerticalOptions="Center"/>
                            </Border>
                        </VerticalStackLayout>
                    </StackLayout>
                </Grid>
            </Border>

            <!-- BOTTOM: Player's Hand -->
            <Border Grid.Row="2" 
                    BackgroundColor="#1A3010" 
                    Stroke="#4A7029"
                    StrokeThickness="2"
                    Padding="10">
                <VerticalStackLayout Spacing="8">
                    <HorizontalStackLayout HorizontalOptions="Center" Spacing="20">
                        <Label Text="Your Hand" 
                               FontSize="18" 
                               FontAttributes="Bold"
                               TextColor="White"/>
                        <Label x:Name="PlayerTricksLabel"
                               Text="Tricks: 0"
                               FontSize="14"
                               TextColor="LightGray"/>
                    </HorizontalStackLayout>

                    <!-- Player's Hand (clickable cards) -->
                    <CollectionView x:Name="PlayerHandCollection"
                                   HeightRequest="130"
                                   HorizontalOptions="Center"
                                   SelectionMode="None">
                        <CollectionView.ItemsLayout>
                            <LinearItemsLayout Orientation="Horizontal" 
                                             ItemSpacing="5"/>
                        </CollectionView.ItemsLayout>
                        <CollectionView.ItemTemplate>
                            <DataTemplate>
                                <Border BackgroundColor="White"
                                        Stroke="{Binding BorderColor}"
                                        StrokeThickness="{Binding BorderThickness}"
                                        WidthRequest="85"
                                        HeightRequest="110"
                                        Margin="2">
                                    <Border.StrokeShape>
                                        <RoundRectangle CornerRadius="8"/>
                                    </Border.StrokeShape>
                                    <Label Text="{Binding DisplayText}" 
                                           FontSize="32"
                                           FontAttributes="Bold"
                                           TextColor="{Binding TextColor}"
                                           HorizontalOptions="Center"
                                           VerticalOptions="Center"/>
                                    <Border.GestureRecognizers>
                                        <TapGestureRecognizer Tapped="OnPlayerCardTapped"/>
                                    </Border.GestureRecognizers>
                                </Border>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </VerticalStackLayout>
            </Border>
        </Grid>

        <!-- RIGHT COLUMN: Control Panel & Status -->
        <Border Grid.Column="1"
                BackgroundColor="#1A3010"
                Stroke="#4A7029"
                StrokeThickness="2"
                Padding="12"
                Margin="5,0,0,0">
            <ScrollView>
                <VerticalStackLayout Spacing="12">
                    
                    <!-- AI Analysis Section (Moved to Top) -->
                    <Label Text="AI Analysis"
                           FontSize="14"
                           FontAttributes="Bold"
                           TextColor="White"/>

                    <Border BackgroundColor="#0F1F0A"
                            Stroke="#4A7029"
                            StrokeThickness="1"
                            Padding="8"
                            HeightRequest="140">
                        <ScrollView>
                            <Label x:Name="AIAnalysisLabel"
                                   FontSize="11"
                                   TextColor="LightGray"
                                   LineBreakMode="WordWrap"
                                   Text="Waiting for AI move..."/>
                        </ScrollView>
                    </Border>

                    <BoxView HeightRequest="2" Color="#4A7029" Margin="0,5"/>

                    <!-- Game Controls -->
                    <Label Text="Game Controls"
                           FontSize="14"
                           FontAttributes="Bold"
                           TextColor="White"/>

                    <Button x:Name="NewGameButton"
                            Text="New Game"
                            Clicked="OnNewGameClicked"
                            BackgroundColor="#4CAF50"
                            TextColor="White"
                            FontSize="12"
                            HeightRequest="36"/>

                    <!-- Manual AI Control Buttons -->
                    <Grid ColumnDefinitions="*,*" ColumnSpacing="8">
                        <Button Grid.Column="0"
                                x:Name="MakeAIMoveButton"
                                Text="AI Move"
                                Clicked="OnMakeAIMoveClicked"
                                BackgroundColor="#FF9800"
                                TextColor="White"
                                FontSize="12"
                                HeightRequest="36"
                                IsEnabled="False"/>
                        
                        <Button Grid.Column="1"
                                x:Name="AnalyzePositionButton"
                                Text="Analyze Position"
                                Clicked="OnAnalyzePositionClicked"
                                BackgroundColor="#2196F3"
                                TextColor="White"
                                FontSize="12"
                                HeightRequest="36"
                                IsEnabled="False"/>
                    </Grid>

                    <BoxView HeightRequest="2" Color="#4A7029" Margin="0,8"/>

                    <!-- Game Settings Section -->
                    <Label Text="Game Settings"
                           FontSize="14"
                           FontAttributes="Bold"
                           TextColor="White"/>

                    <!-- Cards Per Player -->
                    <Label Text="Cards Per Player"
                           FontSize="12"
                           FontAttributes="Bold"
                           TextColor="White"
                           Margin="0,4,0,0"/>

                    <Grid ColumnDefinitions="*,80" ColumnSpacing="8">
                        <Slider Grid.Column="0"
                                x:Name="CardsPerPlayerSlider"
                                Minimum="1"
                                Maximum="10"
                                Value="10"
                                MinimumTrackColor="#4CAF50"
                                MaximumTrackColor="#888"
                                ThumbColor="White"
                                ValueChanged="OnCardsPerPlayerChanged"/>
                        <Label Grid.Column="1"
                               x:Name="CardsPerPlayerLabel"
                               Text="10 cards"
                               FontSize="12"
                               TextColor="White"
                               VerticalOptions="Center"
                               HorizontalOptions="End"/>
                    </Grid>

                    <!-- Game Mode Selection -->
                    <Label Text="Game Mode"
                           FontSize="12"
                           FontAttributes="Bold"
                           TextColor="White"
                           Margin="0,8,0,0"/>

                    <Picker x:Name="GameModePicker"
                            Title="Select Mode"
                            TitleColor="White"
                            BackgroundColor="White"
                            TextColor="Black" 
                            FontSize="12"
                            HeightRequest="60"
                            SelectedIndex="1"
                            SelectedIndexChanged="OnGameModeChanged">
                        <Picker.Items>
                            <x:String>Real Game (Hidden Cards)</x:String>
                            <x:String>Test Mode (All Cards Visible)</x:String>
                        </Picker.Items>
                    </Picker>

                    <!-- AI Strategy Selection -->
                    <Label Text="AI Strategy"
                           FontSize="12"
                           FontAttributes="Bold"
                           TextColor="White"
                           Margin="0,8,0,0"/>

                    <Picker x:Name="AIStrategyPicker"
                            Title="Select Strategy"
                            TitleColor="White" 
                            BackgroundColor="White"
                            TextColor="Black"
                            FontSize="12"
                            HeightRequest="60"
                            SelectedIndex="0"
                            SelectedIndexChanged="OnAIStrategyChanged">
                        <Picker.Items>
                            <x:String>Suit Control Only</x:String>
                            <x:String>Perfect Info (Legacy)</x:String>
                            <x:String>Perfect Game Tree</x:String>
                            <x:String>Monte Carlo (100 sims)</x:String>
                            <x:String>Monte Carlo (500 sims)</x:String>
                            <x:String>Monte Carlo + Perfect Game</x:String>
                        </Picker.Items>
                    </Picker>

                    <!-- Game Status -->
                    <BoxView HeightRequest="2" Color="#4A7029" Margin="0,8"/>

                    <Label Text="Game Status"
                           FontSize="12"
                           FontAttributes="Bold"
                           TextColor="White"/>

                    <Label x:Name="GameStatusLabel"
                           Text="No game in progress"
                           FontSize="11"
                           TextColor="LightGray"
                           LineBreakMode="WordWrap"/>

                    <!-- Score Display -->
                    <BoxView HeightRequest="2" Color="#4A7029" Margin="0,8"/>

                    <Label Text="Current Scores"
                           FontSize="12"
                           FontAttributes="Bold"
                           TextColor="White"/>

                    <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto" RowSpacing="5">
                        <Label Grid.Row="0" Grid.Column="0"
                               Text="You:"
                               FontSize="11"
                               TextColor="White"/>
                        <Label Grid.Row="0" Grid.Column="1"
                               x:Name="PlayerScoreLabel"
                               Text="0 tricks"
                               FontSize="11"
                               TextColor="LightGreen"
                               HorizontalOptions="End"/>

                        <Label Grid.Row="1" Grid.Column="0"
                               Text="Bot:"
                               FontSize="11"
                               TextColor="White"/>
                        <Label Grid.Row="1" Grid.Column="1"
                               x:Name="BotScoreLabel"
                               Text="0 tricks"
                               FontSize="11"
                               TextColor="LightCoral"
                               HorizontalOptions="End"/>
                    </Grid>

                    <!-- Message Log -->
                    <BoxView HeightRequest="2" Color="#4A7029" Margin="0,8"/>

                    <Label Text="Game Log"
                           FontSize="12"
                           FontAttributes="Bold"
                           TextColor="White"/>

                    <Border BackgroundColor="#0F1F0A"
                            Stroke="#4A7029"
                            StrokeThickness="1"
                            Padding="8"
                            HeightRequest="160">
                        <ScrollView x:Name="LogScrollView">
                            <Label x:Name="GameLogLabel"
                                   FontSize="10"
                                   TextColor="LightGray"
                                   LineBreakMode="WordWrap"/>
                        </ScrollView>
                    </Border>

                </VerticalStackLayout>
            </ScrollView>
        </Border>
    </Grid>
</ContentPage>