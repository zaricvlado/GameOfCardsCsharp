<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="GameOfCardsCsharp.Maui.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:GameOfCardsCsharp.Maui"
    Shell.FlyoutBehavior="Flyout"
    Title="GameOfCardsCsharp.Maui">

    <FlyoutItem Title="Tablic Game">
        <ShellContent
            x:Name="TablicGameShellContent"
            Title="Tablic"
            Route="TablicGamePage" />
    </FlyoutItem>

    <FlyoutItem Title="Sample Game">
        <ShellContent
            Title="Sample"
            ContentTemplate="{DataTemplate local:MainPage}"
            Route="MainPage" />
    </FlyoutItem>

</Shell>
