<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:models="clr-namespace:GameOfCardsCsharp.Maui.Models"
             x:Class="GameOfCardsCsharp.Maui.TablicGamePage"
             Title="Tablic Game"
             BackgroundColor="#2D5016">

    <!-- Main Two-Column Layout -->
    <Grid ColumnDefinitions="*,300" Padding="10">

        <!-- LEFT COLUMN: Game Board (Cards) -->
        <Grid Grid.Column="0" 
              RowDefinitions="Auto,*,Auto" 
              Padding="5"
              RowSpacing="5">

            <!-- Top: AI Opponent's Hand -->
            <Border Grid.Row="0" 
                    BackgroundColor="#1A3010" 
                    Stroke="#4A7029"
                    StrokeThickness="2"
                    Padding="8">
                <VerticalStackLayout Spacing="5">
                    <Label Text="AI Opponent" 
                           FontSize="16" 
                           FontAttributes="Bold"
                           TextColor="White"
                           HorizontalOptions="Center"/>

                    <!-- Opponent's Hand (cards shown face down) -->
                    <CollectionView x:Name="OpponentHandCollection" 
                                   HeightRequest="90"
                                   HorizontalOptions="Center"
                                   SelectionMode="None">
                        <CollectionView.ItemsLayout>
                            <LinearItemsLayout Orientation="Horizontal" 
                                             ItemSpacing="5"/>
                        </CollectionView.ItemsLayout>
                        <CollectionView.ItemTemplate>
                            <DataTemplate>
                                <Border BackgroundColor="#0D47A1"
                                        Stroke="#1976D2"
                                        StrokeThickness="2"
                                        WidthRequest="60"
                                        HeightRequest="80"
                                        Margin="2">
                                    <Border.StrokeShape>
                                        <RoundRectangle CornerRadius="8"/>
                                    </Border.StrokeShape>
                                    <Label Text="{Binding DisplayText}" 
                                           FontSize="32"
                                           TextColor="White"
                                           HorizontalOptions="Center"
                                           VerticalOptions="Center"/>
                                </Border>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </VerticalStackLayout>
            </Border>

            <!-- Middle: Talon (Play Area) - Takes most vertical space -->
            <Border Grid.Row="1" 
                    BackgroundColor="#1A3010" 
                    Stroke="#4A7029"
                    StrokeThickness="3"
                    Padding="8"
                    VerticalOptions="Fill">
                <Grid>
                    <!-- Talon Cards (clickable) - Centered, NO TITLE -->
                    <CollectionView x:Name="TalonCardsCollection"
                                   HorizontalOptions="Center"
                                   VerticalOptions="Center"
                                   SelectionMode="None">
                        <CollectionView.ItemsLayout>
                            <LinearItemsLayout Orientation="Horizontal" 
                                             ItemSpacing="10"/>
                        </CollectionView.ItemsLayout>
                        <CollectionView.ItemTemplate>
                            <DataTemplate>
                                <Border x:Name="TalonCardBorder"
                                        BackgroundColor="White"
                                        Stroke="Gray"
                                        StrokeThickness="2"
                                        WidthRequest="85"
                                        HeightRequest="110"
                                        Margin="5">
                                    <Border.StrokeShape>
                                        <RoundRectangle CornerRadius="8"/>
                                    </Border.StrokeShape>
                                    <Border.Triggers>
                                        <DataTrigger TargetType="Border" Binding="{Binding IsSelected}" Value="True">
                                            <Setter Property="Stroke" Value="Gold"/>
                                            <Setter Property="StrokeThickness" Value="4"/>
                                            <Setter Property="Scale" Value="1.1"/>
                                        </DataTrigger>
                                    </Border.Triggers>
                                    <Label Text="{Binding DisplayText}" 
                                           FontSize="32"
                                           FontAttributes="Bold"
                                           TextColor="Black"
                                           HorizontalOptions="Center"
                                           VerticalOptions="Center"/>
                                    <Border.GestureRecognizers>
                                        <TapGestureRecognizer Tapped="OnTalonCardTapped"/>
                                    </Border.GestureRecognizers>
                                </Border>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </Grid>
            </Border>

            <!-- Bottom: Player's Hand -->
            <Border Grid.Row="2" 
                    BackgroundColor="#1A3010" 
                    Stroke="#4A7029"
                    StrokeThickness="2"
                    Padding="8">
                <VerticalStackLayout Spacing="5">
                    <Label Text="Your Hand" 
                           FontSize="16" 
                           FontAttributes="Bold"
                           TextColor="White"
                           HorizontalOptions="Center"/>

                    <!-- Player's Hand (clickable cards) -->
                    <CollectionView x:Name="PlayerHandCollection"
                                   HeightRequest="120"
                                   HorizontalOptions="Center"
                                   SelectionMode="None">
                        <CollectionView.ItemsLayout>
                            <LinearItemsLayout Orientation="Horizontal" 
                                             ItemSpacing="5"/>
                        </CollectionView.ItemsLayout>
                        <CollectionView.ItemTemplate>
                            <DataTemplate>
                                <Border x:Name="PlayerCardBorder"
                                        BackgroundColor="White"
                                        Stroke="Blue"
                                        StrokeThickness="2"
                                        WidthRequest="85"
                                        HeightRequest="110"
                                        Margin="2">
                                    <Border.StrokeShape>
                                        <RoundRectangle CornerRadius="8"/>
                                    </Border.StrokeShape>
                                    <Border.Triggers>
                                        <DataTrigger TargetType="Border" Binding="{Binding IsSelected}" Value="True">
                                            <Setter Property="Stroke" Value="LimeGreen"/>
                                            <Setter Property="StrokeThickness" Value="4"/>
                                            <Setter Property="Scale" Value="1.1"/>
                                        </DataTrigger>
                                    </Border.Triggers>
                                    <Label Text="{Binding DisplayText}" 
                                           FontSize="28"
                                           FontAttributes="Bold"
                                           TextColor="{Binding SuitColor}"
                                           HorizontalOptions="Center"
                                           VerticalOptions="Center"/>
                                    <Border.GestureRecognizers>
                                        <TapGestureRecognizer Tapped="OnPlayerCardTapped"/>
                                    </Border.GestureRecognizers>
                                </Border>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </VerticalStackLayout>
            </Border>

        </Grid>

        <!-- RIGHT COLUMN: Control Panel Sidebar -->
        <ScrollView Grid.Column="1">
            <VerticalStackLayout Spacing="15" Padding="10">

                <!-- AI Score Panel -->
                <Border BackgroundColor="#1A3010" 
                        Stroke="#4A7029"
                        StrokeThickness="2"
                        Padding="15">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="10"/>
                    </Border.StrokeShape>
                    <VerticalStackLayout Spacing="8">
                        <Label Text="🤖 AI Opponent" 
                               FontSize="16" 
                               FontAttributes="Bold"
                               TextColor="White"
                               HorizontalOptions="Center"/>
                        
                        <BoxView HeightRequest="1" Color="#4A7029" Margin="0,5"/>
                        
                        <HorizontalStackLayout HorizontalOptions="Center">
                            <Label Text="Total: " 
                                   FontSize="14" 
                                   TextColor="#90EE90"/>
                            <Label x:Name="OpponentScoreLabel" 
                                   Text="0" 
                                   FontSize="18"
                                   FontAttributes="Bold"
                                   TextColor="#FFD700"/>
                        </HorizontalStackLayout>

                        <Grid ColumnDefinitions="*,*,*" 
                              RowDefinitions="Auto,Auto"
                              ColumnSpacing="5"
                              Margin="0,5,0,0">
                            <Label Grid.Row="0" Grid.Column="0" 
                                   Text="🃏 Cards" 
                                   FontSize="10" 
                                   TextColor="#87CEEB"
                                   HorizontalOptions="Center"/>
                            <Label Grid.Row="0" Grid.Column="1" 
                                   Text="⭐ Tricks" 
                                   FontSize="10" 
                                   TextColor="#90EE90"
                                   HorizontalOptions="Center"/>
                            <Label Grid.Row="0" Grid.Column="2" 
                                   Text="🎯 Talon" 
                                   FontSize="10" 
                                   TextColor="#FFA500"
                                   HorizontalOptions="Center"/>
                            
                            <Label Grid.Row="1" Grid.Column="0"
                                   x:Name="OpponentCardsLabel" 
                                   Text="0" 
                                   FontSize="16"
                                   FontAttributes="Bold"
                                   TextColor="White"
                                   HorizontalOptions="Center"/>
                            <Label Grid.Row="1" Grid.Column="1"
                                   x:Name="OpponentTricksLabel" 
                                   Text="0" 
                                   FontSize="16"
                                   FontAttributes="Bold"
                                   TextColor="White"
                                   HorizontalOptions="Center"/>
                            <Label Grid.Row="1" Grid.Column="2"
                                   x:Name="OpponentTalonLabel" 
                                   Text="0" 
                                   FontSize="16"
                                   FontAttributes="Bold"
                                   TextColor="White"
                                   HorizontalOptions="Center"/>
                        </Grid>
                    </VerticalStackLayout>
                </Border>

                <!-- Game Status Panel with Round Info (Option A: Inline) -->
                <Border BackgroundColor="#4A7029" 
                        Stroke="#6A9039"
                        StrokeThickness="2"
                        Padding="12">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="10"/>
                    </Border.StrokeShape>
                    <VerticalStackLayout Spacing="5">
                        <!-- Title with Round Info Inline -->
                        <Grid ColumnDefinitions="*,Auto">
                            <Label Grid.Column="0"
                                   Text="📍 Game Status" 
                                   FontSize="14" 
                                   FontAttributes="Bold"
                                   TextColor="White"
                                   HorizontalOptions="Start"
                                   VerticalOptions="Center"/>
                            <Label Grid.Column="1"
                                   x:Name="RoundInfoLabel" 
                                   Text="Round 1/4" 
                                   FontSize="12"
                                   FontAttributes="Bold"
                                   TextColor="#FFD700"
                                   HorizontalOptions="End"
                                   VerticalOptions="Center"/>
                        </Grid>
                        
                        <BoxView HeightRequest="1" Color="#6A9039" Margin="0,3"/>
                        
                        <Label x:Name="GameStatusLabel" 
                               Text="Press 'New Game' to start" 
                               FontSize="12"
                               TextColor="#FFD700"
                               HorizontalOptions="Center"
                               HorizontalTextAlignment="Center"
                               LineBreakMode="WordWrap"/>
                    </VerticalStackLayout>
                </Border>

                <!-- Player Score Panel (moved up) -->
                <Border BackgroundColor="#1A3010" 
                        Stroke="#4A7029"
                        StrokeThickness="2"
                        Padding="15">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="10"/>
                    </Border.StrokeShape>
                    <VerticalStackLayout Spacing="8">
                        <Label Text="👤 Your Score" 
                               FontSize="16" 
                               FontAttributes="Bold"
                               TextColor="White"
                               HorizontalOptions="Center"/>
                        
                        <BoxView HeightRequest="1" Color="#4A7029" Margin="0,5"/>
                        
                        <HorizontalStackLayout HorizontalOptions="Center">
                            <Label Text="Total: " 
                                   FontSize="14" 
                                   TextColor="#90EE90"/>
                            <Label x:Name="PlayerScoreLabel" 
                                   Text="0" 
                                   FontSize="18"
                                   FontAttributes="Bold"
                                   TextColor="#FFD700"/>
                        </HorizontalStackLayout>

                        <Grid ColumnDefinitions="*,*,*" 
                              RowDefinitions="Auto,Auto"
                              ColumnSpacing="5"
                              Margin="0,5,0,0">
                            <Label Grid.Row="0" Grid.Column="0" 
                                   Text="🃏 Cards" 
                                   FontSize="10" 
                                   TextColor="#87CEEB"
                                   HorizontalOptions="Center"/>
                            <Label Grid.Row="0" Grid.Column="1" 
                                   Text="⭐ Tricks" 
                                   FontSize="10" 
                                   TextColor="#90EE90"
                                   HorizontalOptions="Center"/>
                            <Label Grid.Row="0" Grid.Column="2" 
                                   Text="🎯 Talon" 
                                   FontSize="10" 
                                   TextColor="#FFA500"
                                   HorizontalOptions="Center"/>

                            <Label Grid.Row="1" Grid.Column="0"
                                   x:Name="PlayerCardsLabel" 
                                   Text="0" 
                                   FontSize="16"
                                   FontAttributes="Bold"
                                   TextColor="White"
                                   HorizontalOptions="Center"/>
                            <Label Grid.Row="1" Grid.Column="1"
                                   x:Name="PlayerTricksLabel" 
                                   Text="0" 
                                   FontSize="16"
                                   FontAttributes="Bold"
                                   TextColor="White"
                                   HorizontalOptions="Center"/>
                            <Label Grid.Row="1" Grid.Column="2"
                                   x:Name="PlayerTalonLabel" 
                                   Text="0" 
                                   FontSize="16"
                                   FontAttributes="Bold"
                                   TextColor="White"
                                   HorizontalOptions="Center"/>
                        </Grid>
                    </VerticalStackLayout>
                </Border>

                <!-- Game Controls Panel (moved below Your Score) -->
                <Border BackgroundColor="#1A3010" 
                        Stroke="#4A7029"
                        StrokeThickness="2"
                        Padding="15">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="10"/>
                    </Border.StrokeShape>
                    <VerticalStackLayout Spacing="10">
                        <Label Text="⚙️ Game Controls" 
                               FontSize="16" 
                               FontAttributes="Bold"
                               TextColor="White"
                               HorizontalOptions="Center"/>
                        
                        <BoxView HeightRequest="1" Color="#4A7029" Margin="0,5"/>

                        <Button x:Name="NewGameButton"
                                Text="🎮 New Game"
                                Clicked="OnNewGameClicked"
                                BackgroundColor="#4A7029"
                                TextColor="White"
                                FontSize="14"
                                CornerRadius="8"
                                Padding="10"/>

                        <Button x:Name="ShowPossibleMovesButton"
                                Text="💡 Show Hints"
                                Clicked="OnShowPossibleMovesClicked"
                                BackgroundColor="#6A7029"
                                TextColor="White"
                                FontSize="14"
                                CornerRadius="8"
                                Padding="10"
                                IsEnabled="False"/>
                    </VerticalStackLayout>
                </Border>

                <!-- Player Pile Viewer (Expandable) -->
                <Border BackgroundColor="#1A3010" 
                        Stroke="#4A7029"
                        StrokeThickness="2"
                        Padding="15">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="10"/>
                    </Border.StrokeShape>
                    <VerticalStackLayout Spacing="8">
                        <Border BackgroundColor="#2D5016"
                                Padding="10"
                                Stroke="#4A7029"
                                StrokeThickness="1">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="5"/>
                            </Border.StrokeShape>
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnPlayerPileHeaderTapped"/>
                            </Border.GestureRecognizers>
                            <Grid ColumnDefinitions="*,Auto">
                                <HorizontalStackLayout Grid.Column="0" Spacing="5">
                                    <Label Text="🃏" 
                                           FontSize="18"
                                           TextColor="#87CEEB"
                                           VerticalOptions="Center"/>
                                    <Label Text="View My Pile" 
                                           FontSize="14" 
                                           FontAttributes="Bold"
                                           TextColor="White"
                                           VerticalOptions="Center"/>
                                </HorizontalStackLayout>
                                <Label x:Name="PlayerPileExpandIcon"
                                       Grid.Column="1"
                                       Text="▼" 
                                       FontSize="12"
                                       TextColor="#90EE90"
                                       VerticalOptions="Center"/>
                            </Grid>
                        </Border>

                        <VerticalStackLayout x:Name="PlayerPileContent"
                                           IsVisible="False"
                                           Spacing="5">
                            <BoxView HeightRequest="1" Color="#4A7029" Margin="0,5"/>
                            
                            <FlexLayout x:Name="PlayerPileCardsLayout"
                                      Wrap="Wrap"
                                      JustifyContent="Start"
                                      AlignItems="Start"
                                      Direction="Row">
                            </FlexLayout>
                            
                            <Label x:Name="PlayerPileEmptyLabel"
                                   Text="No cards captured yet" 
                                   FontSize="12"
                                   TextColor="#808080"
                                   HorizontalOptions="Center"
                                   Margin="0,10,0,10"/>
                        </VerticalStackLayout>
                    </VerticalStackLayout>
                </Border>

                <!-- Move History Panel -->
                <Border BackgroundColor="#1A3010" 
                        Stroke="#4A7029"
                        StrokeThickness="2"
                        Padding="15">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="10"/>
                    </Border.StrokeShape>
                    <VerticalStackLayout Spacing="8">
                        <Border BackgroundColor="#2D5016"
                                Padding="10"
                                Stroke="#4A7029"
                                StrokeThickness="1">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="5"/>
                            </Border.StrokeShape>
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnMoveHistoryHeaderTapped"/>
                            </Border.GestureRecognizers>
                            <Grid ColumnDefinitions="*,Auto">
                                <HorizontalStackLayout Grid.Column="0" Spacing="5">
                                    <Label Text="📜" FontSize="16"/>
                                    <Label Text="Move History" 
                                           FontSize="14" 
                                           FontAttributes="Bold"
                                           TextColor="White"
                                           VerticalOptions="Center"/>
                                </HorizontalStackLayout>
                                <Label x:Name="MoveHistoryExpandIcon"
                                       Grid.Column="1"
                                       Text="▼" 
                                       FontSize="12"
                                       TextColor="#90EE90"
                                       VerticalOptions="Center"/>
                            </Grid>
                        </Border>

                        <VerticalStackLayout x:Name="MoveHistoryContent"
                                           IsVisible="False"
                                           Spacing="5">
                            <BoxView HeightRequest="1" Color="#4A7029" Margin="0,5"/>

                            <ScrollView MaximumHeightRequest="300">
                                <VerticalStackLayout x:Name="MoveHistoryStack" 
                                                   Spacing="5">
                                    <Label Text="No moves yet" 
                                           FontSize="12"
                                           TextColor="#808080"
                                           HorizontalOptions="Center"
                                           Margin="0,20,0,0"/>
                                </VerticalStackLayout>
                            </ScrollView>
                        </VerticalStackLayout>
                    </VerticalStackLayout>
                </Border>

                <!-- Debug Panel -->
                <Border BackgroundColor="#1A1A2E" 
                        Stroke="#4A4A7A"
                        StrokeThickness="2"
                        Padding="15">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="10"/>
                    </Border.StrokeShape>
                    <VerticalStackLayout Spacing="10">
                        <Label Text="🐛 Debug &amp; Logging"
                               FontSize="14" 
                               FontAttributes="Bold"
                               TextColor="#FFD700"
                               HorizontalOptions="Center"/>
                        
                        <BoxView HeightRequest="1" Color="#4A4A7A" Margin="0,5"/>
                        
                        <Grid ColumnDefinitions="*,Auto" Margin="0,5">
                            <Label Grid.Column="0"
                                   Text="Enable Logging" 
                                   FontSize="12"
                                   TextColor="White"
                                   VerticalOptions="Center"/>
                            <Switch Grid.Column="1"
                                    x:Name="LoggingEnabledSwitch"
                                    IsToggled="False"
                                    Toggled="OnLoggingToggled"
                                    OnColor="#4CAF50"
                                    ThumbColor="White"/>
                        </Grid>
                        
                        <Label x:Name="LoggingStatusLabel"
                               Text="❌ Logging Disabled" 
                               FontSize="10"
                               TextColor="#FF6B6B"
                               HorizontalOptions="Center"/>
                        
                        <BoxView HeightRequest="1" Color="#3A3A5A" Margin="0,5"/>
                        
                        <Label Text="Log Level:" 
                               FontSize="11"
                               TextColor="White"/>
                        
                        <Picker x:Name="LogLevelPicker"
                                SelectedIndex="0"
                                SelectedIndexChanged="OnLogLevelChanged"
                                BackgroundColor="#2A2A4A"
                                TextColor="White"
                                FontSize="11">
                            <Picker.Items>
                                <x:String>Debug</x:String>
                                <x:String>Info</x:String>
                                <x:String>Warning</x:String>
                                <x:String>Error</x:String>
                            </Picker.Items>
                        </Picker>
                        
                        <BoxView HeightRequest="1" Color="#3A3A5A" Margin="0,5"/>
                        
                        <Label Text="Current Log:" 
                               FontSize="10"
                               TextColor="#90EE90"/>
                        
                        <Label x:Name="LogFilePathLabel"
                               Text="No log file" 
                               FontSize="8"
                               TextColor="#87CEEB"
                               LineBreakMode="TailTruncation"
                               MaxLines="2"/>
                        
                        <Grid ColumnDefinitions="*,*" ColumnSpacing="5" Margin="0,5,0,0">
                            <Button Grid.Column="0"
                                    Text="📂 Folder"
                                    Clicked="OnOpenLogFolderClicked"
                                    BackgroundColor="#4A4A7A"
                                    TextColor="White"
                                    FontSize="10"
                                    CornerRadius="5"
                                    Padding="6"/>
                            
                            <Button Grid.Column="1"
                                    x:Name="ShareLogButton"
                                    Text="📤 Share"
                                    Clicked="OnShareLogFileClicked"
                                    BackgroundColor="#4A4A7A"
                                    TextColor="White"
                                    FontSize="10"
                                    CornerRadius="5"
                                    Padding="6"
                                    IsEnabled="False"/>
                        </Grid>
                        
                        <BoxView HeightRequest="1" Color="#3A3A5A" Margin="0,5"/>
                        
                        <Label x:Name="SessionInfoLabel"
                               Text="Turn on logging before starting a new game" 
                               FontSize="9"
                               TextColor="#87CEEB"
                               LineBreakMode="WordWrap"
                               HorizontalTextAlignment="Center"/>
                    </VerticalStackLayout>
                </Border>

                <!-- Game Setup Panel (First Player) -->
                <Border BackgroundColor="#1A3010"
                        Stroke="#4A7029"
                        StrokeThickness="2"
                        Padding="15">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="10"/>
                    </Border.StrokeShape>
                    <VerticalStackLayout Spacing="10">
                        <Label Text="⚙️ Game Setup"
                               FontSize="16"
                               FontAttributes="Bold"
                               TextColor="White"
                               HorizontalOptions="Center"/>

                        <BoxView HeightRequest="1" Color="#4A7029" Margin="0,5"/>

                        <Grid ColumnDefinitions="Auto,*" ColumnSpacing="8">
                            <Label Grid.Column="0"
                                   Text="First Player:"
                                   FontSize="13"
                                   FontAttributes="Bold"
                                   TextColor="White"
                                   VerticalOptions="Center"/>
                            <Picker Grid.Column="1"
                                    x:Name="FirstPlayerPicker"
                                    SelectedIndex="2"
                                    SelectedIndexChanged="OnFirstPlayerChanged"
                                    BackgroundColor="#2A4A1A"
                                    TextColor="White"
                                    FontSize="13">
                                <Picker.Items>
                                    <x:String>👤 You</x:String>
                                    <x:String>🤖 AI</x:String>
                                    <x:String>🎲 Random</x:String>
                                </Picker.Items>
                            </Picker>
                        </Grid>

                        <Label Text="Choose before pressing 'New Game'"
                               FontSize="10"
                               TextColor="#87CEEB"
                               HorizontalOptions="Center"
                               HorizontalTextAlignment="Center"/>
                    </VerticalStackLayout>
                </Border>

            </VerticalStackLayout>
        </ScrollView>

    </Grid>

</ContentPage>